      measurement.specification = setupRef(mainSpecs.ARPS1020A5_tf_REV02.Spc_Lev_eqn3_spec1_set1_Tim_eqn5_spec1_set1);
    }
    suite Disconnect_ALL_4_1_1 calls empty.EMPTY { }
    suite UVLO_POR_redundancy_AWG calls CROW_ARPS10X0X5_TM.Crow_tml.UVLO_AWGMethod {
      // missing Level setup in specification;
      // measurement.specification = setupRef(mainSpecs.ARPS1020A5_tf_REV02.Spc_Tim_eqn5_spec1_set1);
      bypass = true;
    }
    suite UVLO_POR_redundancy calls empty.EMPTY { }
    suite Disconnect_ALL_4_2_1 calls empty.EMPTY { }
    suite ILIM_block_offset_Trim_hcu calls CROW_ARPS10X0X5_TM.ILIM_block_offset_Trim {
      measurement.specification = setupRef(mainSpecs.ARPS1020A5_tf_REV02.Spc_Lev_eqn3_spec1_set1_Tim_eqn5_spec1_set1);
      bypass = true;
    }
    suite ILIM_block_offset_Trim_ppmu calls CROW_ARPS10X0X5_TM.Crow_tml.ILIM_block_offset_Trim_ppmu {
      measurement.specification = setupRef(mainSpecs.ARPS1020A5_tf_REV02.Spc_Lev_eqn3_spec1_set1_Tim_eqn5_spec1_set1);
      bypass = true;
    }
    suite ILIM_gain_Trim calls CROW_ARPS10X0X5_TM.Crow_tml.ILIM_gain_Trim {
      measurement.specification = setupRef(mainSpecs.ARPS1020A5_tf_REV02.Spc_Lev_eqn3_spec1_set1_Tim_eqn5_spec1_set1);
      bypass = true;
    }
    suite ILIMI_GAIN_TRIM_25PIMAX calls CROW_ARPS10X0X5_TM.Crow_tml.ILIM_gain_TRIM_25PIMAX {
      measurement.specification = setupRef(mainSpecs.ARPS1020A5_tf_REV02.Spc_Lev_eqn3_spec1_set1_Tim_eqn5_spec1_set1);
    }
    suite Disconnect_ALL_4_2_1_2 calls empty.EMPTY { }
    suite ISENSE_BlockOffset_Trim_New calls CROW_ARPS10X0X5_TM.Crow_tml.ISENSE_blockOffset_trim_New {
      measurement.specification = setupRef(mainSpecs.ARPS1020A5_tf_REV02.Spc_Lev_eqn3_spec1_set1_Tim_eqn5_spec1_set1);
    }
    suite SNS_gain_Trim calls CROW_ARPS10X0X5_TM.Crow_tml.SNS_gain_Trim {
      measurement.specification = setupRef(mainSpecs.ARPS1020A5_tf_REV02.Spc_Lev_eqn3_spec1_set1_Tim_eqn5_spec1_set1);
      bypass = true;
    }
    suite Disconnect_ALL_4_2_1_1 calls empty.EMPTY { }
    suite SNS_gain_Trim_25PIMAX calls CROW_ARPS10X0X5_TM.Crow_tml.SNS_gain_Trim_25PIMAX {
      measurement.specification = setupRef(mainSpecs.ARPS1020A5_tf_REV02.Spc_Lev_eqn3_spec1_set1_Tim_eqn5_spec1_set1);
    }
    suite OC_Delay_Trim calls CROW_ARPS10X0X5_TM.Crow_tml.OC_Delay_Trim {
      measurement.specification = setupRef(mainSpecs.ARPS1020A5_tf_REV02.Spc_Lev_eqn3_spec1_set1_Tim_eqn5_spec1_set1);
    }
    suite PostVref_Iref_ib1u calls CROW_ARPS10X0X5_TM.Crow_tml.Post_Vreftrim_Ireftrim {
