flow Trim_Test {
  setup {
    suite Vreftrim calls CROW_ARPS10X0X5_TM.Crow_tml.Vreftrim {
      measurement.specification = setupRef(mainSpecs.ARPS1020A5_tf_REV02.Spc_Lev_eqn3_spec1_set1_Tim_eqn5_spec1_set1);
    }
    suite Disconnect_ALL_4_2 calls empty.EMPTY { }
    suite SS_Current_Trim calls CROW_ARPS10X0X5_TM.Crow_tml.SS_Current_Trim {
      measurement.specification = setupRef(mainSpecs.ARPS1020A5_tf_REV02.Spc_Lev_eqn3_spec1_set1_Tim_eqn5_spec1_set1);
    }
    suite SS_Gain calls CROW_ARPS10X0X5_TM.Crow_tml.SS_Gain {
      measurement.specification = setupRef(mainSpecs.ARPS1020A5_tf_REV02.Spc_Lev_eqn3_spec1_set1_Tim_eqn5_spec1_set1);
    }
    suite SSoffset_Trim calls CROW_ARPS10X0X5_TM.Crow_tml.SSoffset_Trim {
      measurement.specification = setupRef(mainSpecs.ARPS1020A5_tf_REV02.Spc_Lev_eqn3_spec1_set1_Tim_eqn5_spec1_set1);
    }
