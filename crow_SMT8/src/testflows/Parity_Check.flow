flow Parity_Check {
  setup {
    suite EFUSE_PARITY_DURING_READ calls CROW_ARPS10X0X5_TM.Crow_tml.E_fuse_parity_during_read {
      measurement.specification = setupRef(mainSpecs.ARPS1020A5_tf_REV02.Spc_Lev_eqn3_spec1_set1_Tim_eqn5_spec1_set1);
    }
    suite Disconnect_ALL_1_2_1_1 calls empty.EMPTY { }
    suite EFUSE_parity_after_read calls CROW_ARPS10X0X5_TM.Crow_tml.E_fuse_parity_after_read {
      measurement.specification = setupRef(mainSpecs.ARPS1020A5_tf_REV02.Spc_Lev_eqn3_spec1_set1_Tim_eqn5_spec1_set1);
    }
  }
  execute {
    EFUSE_PARITY_DURING_READ.execute();
    if(EFUSE_PARITY_DURING_READ.pass) { }
    else {
      // multi_bin;
    }
    Disconnect_ALL_1_2_1_1.execute();
    EFUSE_parity_after_read.execute();
    if(EFUSE_parity_after_read.pass) { }
    else {
      // multi_bin;
    }
  }
}
