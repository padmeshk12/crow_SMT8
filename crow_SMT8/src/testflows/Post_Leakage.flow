flow Post_Leakage {
  setup {
    suite Disconnect_ALL_3_1_3 calls empty.EMPTY { }
    suite Post_Output_disabled_leakage calls CROW_ARPS10X0X5_TM.Crow_tml.Output_disabled_VDD_VIN {
      measurement.specification = setupRef(mainSpecs.ARPS1020A5_tf_REV02.Spc_Lev_eqn3_spec1_set1_Tim_eqn5_spec1_set1);
    }
    suite Post_Leakage_Test calls CROW_ARPS10X0X5_TM.Leakage_Test {
      measurement.specification = setupRef(mainSpecs.ARPS1020A5_tf_REV02.Spc_Lev_eqn3_spec1_set1_Tim_eqn5_spec1_set1);
    }
    suite Post_Nominal_Input_pin_Leakages calls CROW_ARPS10X0X5_TM.Nominal_Input_leakage {
      measurement.specification = setupRef(mainSpecs.ARPS1020A5_tf_REV02.Spc_Lev_eqn3_spec1_set1_Tim_eqn5_spec1_set1);
    }
    suite Post_Output_enabled_leakage calls CROW_ARPS10X0X5_TM.Crow_tml.Output_enabled_Leakage_initial_debug {
      measurement.specification = setupRef(mainSpecs.ARPS1020A5_tf_REV02.Spc_Lev_eqn3_spec1_set1_Tim_eqn5_spec1_set1);
    }
  }
  execute {
    Disconnect_ALL_3_1_3.execute();
    Post_Output_disabled_leakage.execute();
    if(Post_Output_disabled_leakage.pass) { }
    else {
      // multi_bin;
    }
    Post_Leakage_Test.execute();
    if(Post_Leakage_Test.pass) { }
    else {
      // multi_bin;
    }
    Post_Nominal_Input_pin_Leakages.execute();
    if(Post_Nominal_Input_pin_Leakages.pass) { }
    else {
      // multi_bin;
    }
    Post_Output_enabled_leakage.execute();
    if(Post_Output_enabled_leakage.pass) { }
    else {
      // multi_bin;
    }
  }
}
